# Anthropic
ANTHROPIC_API_KEY=

# Models
MANAGER_MODEL=claude-sonnet-4-6
WORKER_MODEL=claude-haiku-4-5-20251001

# Per-agent model routing — set OUTFIT_MODEL=qwen/qwen3.5-9b to use local LM Studio instead
OUTFIT_MODEL=claude-haiku-4-5-20251001
OCCASION_MODEL=claude-haiku-4-5-20251001

# LM Studio local server (required when OUTFIT_MODEL is a local model)
LM_STUDIO_URL=http://localhost:1234/v1

# Neo4j AuraDB
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Paths
SQLITE_DB_PATH=data/seed/wardrobe.db
CHROMA_PERSIST_DIR=.cache/chroma
MEMORY_STORE_PATH=data/memory

# Security (agents never see this; only the LangGraph record_wear node passes it)
WEAR_SECRET=

# API
API_HOST=0.0.0.0
API_PORT=8000

# Geocoding for city -> lat/lon (Open-Meteo weather is free; geocoding needs a key)
# Free tier: https://api.api-ninjas.com  or  https://opencagedata.com
GEOCODING_API_KEY=
